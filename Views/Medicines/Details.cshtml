@model PharmacyPOS.Models.Medicine
@{
    ViewData["Title"] = "Medicine Details";
}

<div class="page-card p-4">
    <h3>Medicine Details</h3>
    <dl class="row mt-3">
        <dt class="col-sm-3">Code</dt><dd class="col-sm-9">@Model.Code</dd>
        <dt class="col-sm-3">Brand Name</dt><dd class="col-sm-9">@Model.BrandName</dd>
        <dt class="col-sm-3">Generic Name</dt><dd class="col-sm-9">@Model.GenericName</dd>
        <dt class="col-sm-3">Category</dt><dd class="col-sm-9">@Model.Category</dd>
        <dt class="col-sm-3">Price</dt><dd class="col-sm-9">@Model.Price.ToString("C")</dd>
        <dt class="col-sm-3">Stock</dt><dd class="col-sm-9">@Model.Stock</dd>
        <dt class="col-sm-3">Expiry Date</dt><dd class="col-sm-9">@Model.ExpiryDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
    </dl>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>