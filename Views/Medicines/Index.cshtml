@model PharmacyPOS.Models.MedicineIndexViewModel
@{
    ViewData["Title"] = "Medicine Inventory";
}

<div class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h3 class="mb-1">Medicine Inventory</h3>
            <p class="text-muted mb-0">Manage medicine records with dynamic filtering and CRUD actions.</p>
        </div>
        <a asp-action="Create" class="btn btn-danger"><i class="bi bi-plus-circle me-1"></i> Add Medicine</a>
    </div>

    @if (TempData["Success"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input name="search" value="@Model.Search" class="form-control" placeholder="Search code / brand / generic" />
        </div>
        <div class="col-md-3">
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">All Status</option>
                @foreach (var item in new[] { "In Stock", "Low Stock", "Out of Stock" })
                {
                    <option value="@item" selected="@(Model.Status == item)">@item</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-outline-danger" type="submit">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Brand Name</th>
                    <th>Generic Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Expiry Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Medicines.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No medicine records found.</td></tr>
                }
                else
                {
                    @foreach (var med in Model.Medicines)
                    {
                        <tr>
                            <td>@med.Code</td>
                            <td>@med.BrandName</td>
                            <td>@med.GenericName</td>
                            <td>@med.Category</td>
                            <td>@med.Price.ToString("C")</td>
                            <td>@med.Stock</td>
                            <td>@med.ExpiryDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (med.Status == "In Stock")
                                {
                                    <span class="badge text-bg-success badge-status">In Stock</span>
                                }
                                else if (med.Status == "Low Stock")
                                {
                                    <span class="badge text-bg-warning badge-status">Low Stock</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger badge-status">Out of Stock</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@med.Id" class="btn btn-outline-secondary">View</a>
                                    <a asp-action="Edit" asp-route-id="@med.Id" class="btn btn-outline-primary">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@med.Id" method="post" onsubmit="return confirm('Delete this medicine?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>