@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();

    string IsActive(string controller, string? action = null)
    {
        if (!currentController.Equals(controller.ToLowerInvariant())) return string.Empty;
        if (string.IsNullOrWhiteSpace(action)) return "active";
        return currentAction.Equals(action.ToLowerInvariant()) ? "active" : string.Empty;
    }

    var isLoggedIn = !string.IsNullOrWhiteSpace(Context.Session.GetString("Username"));
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SafeMed Pharmacy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PharmacyPOS.styles.css" asp-append-version="true" />
    
</head>
<body>
    @if (isLoggedIn)
    {
        <div class="app-shell">
            <aside class="sidebar">
                <div class="sidebar-header">
                    <img src="~/images/logo.png" alt="SafeMed Logo" class="sidebar-logo" />
                    <h5>SafeMed Admin</h5>
                    <small>Full Access</small>
                </div>

                <nav class="sidebar-nav">
                    <a class="sidebar-link @IsActive("Dashboard")" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    <a class="sidebar-link @IsActive("Medicines")" asp-controller="Medicines" asp-action="Index"><i class="bi bi-capsule-pill"></i> Medicine Inventory</a>
                    <a class="sidebar-link @IsActive("Modules", "Pos")" asp-controller="Modules" asp-action="Pos"><i class="bi bi-cart-check"></i> POS / Sales</a>
                    <a class="sidebar-link @IsActive("Modules", "Payment")" asp-controller="Modules" asp-action="Payment"><i class="bi bi-cash-coin"></i> Payment</a>
                    <a class="sidebar-link @IsActive("Modules", "Receipt")" asp-controller="Modules" asp-action="Receipt"><i class="bi bi-receipt"></i> Receipt</a>
                    <a class="sidebar-link @IsActive("Modules", "SalesHistory")" asp-controller="Modules" asp-action="SalesHistory"><i class="bi bi-clock-history"></i> Sales History</a>
                    <a class="sidebar-link @IsActive("Modules", "Reports")" asp-controller="Modules" asp-action="Reports"><i class="bi bi-bar-chart"></i> Reports</a>
                    <a class="sidebar-link @IsActive("Modules", "StockAlerts")" asp-controller="Modules" asp-action="StockAlerts"><i class="bi bi-exclamation-triangle"></i> Stock Alerts</a>
                </nav>

                <form asp-controller="Auth" asp-action="Logout" method="post" class="logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-light w-100 text-danger fw-semibold">Logout</button>
                </form>
            </aside>

            <div class="main-panel">
                <main class="content-area">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>